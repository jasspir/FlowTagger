{
  "schemaVersion": 1,
  "id": "flowtagger",
  "version": "${version}",
  "name": "FlowTagger",
  "description": "Clientside mod that displays flowpvp.gg ranks on nametags, tab, & chat (use /flowtagger to configure)",
  "authors": ["Jass"],
  "contact" : {
    "homepage" : "https://modrinth.com/mod/flowtagger",
    "sources" : "https://github.com/jasspir/FlowTagger",
    "issues" : "https://github.com/jasspir/FlowTagger/issues"
  },
  "license": "Apache-2.0",
  "icon": "assets/flowtagger/icon.png",
  "environment": "client",
  "entrypoints": {
    "main": [
      "you.jass.flowtagger.FlowTagger"
    ]
  },
  "mixins": [
    "flowtagger.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  },
  "custom" : {
    "modmenu" : {
      "links" : {
        "modmenu.modrinth" : "https://modrinth.com/mod/flowtagger"
      }
    }
  }
}
